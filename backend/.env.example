# Application
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/smartgov
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/smartgov

# Redis
REDIS_URL=redis://localhost:6379/0

# AI
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...          # optional fallback

# Search (Meilisearch)
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=masterKey

# Storage (Cloudflare R2 / S3)
S3_BUCKET=smartgov-docs
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_REGION=auto

# OCR
TESSERACT_CMD=/usr/bin/tesseract

# Rate limiting (requests per second per domain)
SCRAPER_RPS=1
SCRAPER_CONCURRENCY=4

# Scheduler
DAILY_SCRAPE_HOUR=2
DAILY_SCRAPE_MINUTE=0
